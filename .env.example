PAGAMO_ACCOUNT=your_account
PAGAMO_PASSWORD=your_password

# LLM provider: gemini (default) | anthropic
LLM_PROVIDER=gemini

# Google AI Studio (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (optional, only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Seconds to wait before submitting each answer
# Gemini free tier: 10 RPM → needs >=6s. Paid tier: can use 1-2s.
ANSWER_DELAY=7

# Seconds between map-scan hex probes (hexagon_info throttles under rapid scans)
SCAN_DELAY=0.15

# Your starting hex (one of your own territory hexes)
HEX_X=-5121
HEX_Y=-1450

# Your own game character ID (gc_id)
# Find it: DevTools → Network → any /graphql request → look for "id" in gamecharacter response
MY_GC_ID=3389027
