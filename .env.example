PAGAMO_ACCOUNT=your_account
PAGAMO_PASSWORD=your_password

# LLM provider: gemini (default) | anthropic
LLM_PROVIDER=gemini

# Google AI Studio (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (optional, only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Default battle target (can also pass via CLI args)
# Find these by right-clicking a hex in the map and using browser DevTools
HEX_X=-5121
HEX_Y=-1450
TARGET_GC_ID=3389027
