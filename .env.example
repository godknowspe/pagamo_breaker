PAGAMO_ACCOUNT=your_account
PAGAMO_PASSWORD=your_password

# Optional second account used as a real-time answer oracle.
# It looks up official answers for the question the primary account is answering
# (the answer endpoint is blocked in-room, but a second account not in a room can
# query it). When set, answers come from this account instead of the LLM.
# Leave blank to disable.
PAGAMO_ACCOUNT_2=
PAGAMO_PASSWORD_2=

# LLM provider: gemini (default) | anthropic
LLM_PROVIDER=gemini

# Google AI Studio (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# Anthropic (optional, only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Seconds to wait before submitting each answer
# Gemini free tier: 10 RPM → needs >=6s. Paid tier: can use 1-2s.
ANSWER_DELAY=7

# Your starting hex (one of your own territory hexes)
HEX_X=-5121
HEX_Y=-1450

# Your own game character ID (gc_id)
# Find it: DevTools → Network → any /graphql request → look for "id" in gamecharacter response
MY_GC_ID=3389027
